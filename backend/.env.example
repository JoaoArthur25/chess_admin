# Repository: "memory" (default, no DB) or "prisma"
REPO=memory

# Pairing engine: "fake" (default, deterministic) or "bbp" (real bbpPairings)
PAIRING_ENGINE=fake
# Path to the bbpPairings binary when PAIRING_ENGINE=bbp
PAIRING_ENGINE_PATH=bbpPairings

# Required only when REPO=prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chess_admin?schema=public

PORT=4000
